{
  "name": "@dev-arora/tizenflix",
  "version": "0.2.0",
  "description": "TizenBrew streaming client for Tizenflix (educational purposes only)",
  "packageType": "app",
  "appName": "Tizenflix",
  "appPath": "app/index.html",
  "keys": [
    "MediaPlayPause",
    "MediaFastForward",
    "MediaRewind"
  ],
  "license": "MIT",
  "files": [
    "app",
    "package.json",
    "README.md",
    "STRUCTURE.md"
  ],
  "scripts": {
    "build": "npm run build:app && npm run build:gate",
    "build:app": "esbuild app/js/app.js --bundle --outfile=app/dist/app.bundle.js --target=es2015 --format=iife --global-name=TizenflixApp",
    "build:gate": "esbuild app/js/gate/main.js --bundle --outfile=app/dist/gate.bundle.js --target=es2015 --format=iife --global-name=TizenflixGate",
    "dev": "npm run build && node scripts/dev.mjs",
    "start": "npm run build && node scripts/dev.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
