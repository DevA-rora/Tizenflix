{
  "name": "tizenflix-api",
  "version": "0.2.0",
  "description": "Netflix-style streaming API for Tizen TV — Vidking/Videasy resolver + TMDB catalog",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "resolve": "tsx scripts/resolve.mjs",
    "download": "tsx scripts/download.mjs",
    "capture": "node scripts/capture-network.mjs",
    "api": "tsx scripts/server.mjs",
    "save-fixtures": "tsx scripts/save-fixtures.mjs",
    "sample-mp4": "node scripts/sample-mp4.mjs",
    "benchmark-streamflix": "tsx scripts/benchmark-streamflix.mjs",
    "benchmark-tmdb-native": "tsx scripts/benchmark-tmdb-native.mjs",
    "sync-streamflix": "node scripts/sync-streamflix.mjs",
    "setup": "playwright install chromium",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dns-over-https": "^0.1.0",
    "express": "^5.1.0",
    "fetch-cookie": "^3.2.0",
    "playwright": "^1.52.0",
    "tough-cookie": "^6.0.2",
    "undici": "^7.28.0"
  }
}
